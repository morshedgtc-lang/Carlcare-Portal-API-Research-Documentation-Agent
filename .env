# Server
PORT=3000
NODE_ENV=development

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Redis (optional - app falls back gracefully)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="imei-lookup-local-dev-secret-key-change-in-prod"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Carlcare API
CARLCARE_API_BASE_URL="https://service.carlcare.com/CarlcareClient"
CARLCARE_API_KEY=""
CARLCARE_API_SECRET=""

# Thailand auto-submit
THAILAND_MCC="520"
